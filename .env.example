# =============================================================================
# GRPHINTEL — Environment Variables Reference
# Copy this file to .env and fill in your values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection string (Neon or any Postgres-compatible provider)
# Format: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Secret used to sign JWT tokens — use a long, random string (min 32 chars)
# Generate one with: openssl rand -hex 32
SESSION_SECRET=

# -----------------------------------------------------------------------------
# AI Integrations — OpenAI
# -----------------------------------------------------------------------------

# OpenAI API key (or compatible provider key)
AI_INTEGRATIONS_OPENAI_API_KEY=

# Base URL for the OpenAI-compatible API endpoint
# Default: https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# Pipedream Connect
# -----------------------------------------------------------------------------

# Pipedream project credentials (found in your Pipedream project settings)
PIPEDREAM_PROJECT_ID=
PIPEDREAM_PROJECT_SECRET=
PIPEDREAM_PROJECT_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Google OAuth (optional — only needed if Google login is enabled)
# -----------------------------------------------------------------------------

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Inngest (event-driven workflows)
# -----------------------------------------------------------------------------

# Event key used to send events to Inngest
INNGEST_EVENT_KEY=

# Signing key used to verify Inngest webhook payloads
INNGEST_SIGNING_KEY=

# -----------------------------------------------------------------------------
# URLs
# -----------------------------------------------------------------------------

# Public URL of the frontend (Vite dev default: http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Base URL of the API server (used for CORS, redirects, etc.)
API_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Runtime environment: development | production | test
NODE_ENV=development

# Port the API server listens on
PORT=3000

# Log verbosity: error | warn | info | debug (optional, default: info)
LOG_LEVEL=info
